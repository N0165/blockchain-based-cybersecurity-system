# Copy to backend/.env and adjust (or set environment variables).

SECRET_KEY=change-me-long-random
JWT_SECRET=change-me-jwt
JWT_EXPIRATION_HOURS=24

# SQLite default: leave DATABASE_URL unset, or use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://threat:threat_dev@127.0.0.1:5432/threat_intel

ETH_RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=0xYourDeployedContract

# Hardhat account #0 private key (LOCAL ONLY — never use on mainnet)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional: 32-byte Fernet-compatible key for wallet encryption at rest
# ENCRYPTION_KEY=

IPFS_API=/ip4/127.0.0.1/tcp/5001

# Optional bootstrap admin (created once if DB empty)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeAdmin123!
